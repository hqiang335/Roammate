{
  "mcpServers": {
    "amap_maps": {
      "command": "npx",
      "args": ["-y", "@amap/amap-maps-mcp-server"],
      "env": {
        "AMAP_MAPS_API_KEY": "your_amap_maps_api_key_here"
      },
      "startupTimeoutSec": 20
    }
  },
  "env": {
    "AMAP_MAPS_API_KEY": "your_amap_maps_api_key_here",
    "AMAP_WEB_JS_API_KEY": "your_amap_web_js_api_key_here",
    "FLYAI_API_KEY": "your_flyai_api_key_here"
  }
}
